{
  "env": {
    "browser": true,
    "es2022": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "error",
    "consistent-return": "error",
    "no-console": ["error", { "allow": ["warn", "error"] }],
    "max-lines-per-function": ["warn", { "max": 30, "skipBlankLines": true, "skipComments": true }]
  }
}
